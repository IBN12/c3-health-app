<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>C3 Health</title>

        <link rel="stylesheet" href="/styles/homepageStyles.css">
        <link rel="stylesheet" href="/styles/styles.css">
        <link rel="icon" type="image/x-icon" href="/favicon.ico">

        <script type="module" src="/scripting/design/slideshow.js" defer></script>
        <script type="module" src="/scripting/windows/menuWindow.js" defer></script>
    </head>

    <body>
        <!-- Public Navigation Header -->
        <%- include('../utils/nav.ejs') %>

        <!-- Main Menu Window -->
        <%- include('../utils/menuWindow.ejs') %>

        <!-- Main Homepage Container -->
        <main id="homepage-main">

            <!-- Homepage Header Section -->
            <section class="homepage-header">

                <!-- Slideshow -->
                <div class="slideshow-container">

                    <!-- Slide 1: Peptide Inventory -->
                    <div class="slide" data-href="#"> <!-- /inventory -->
                        <div class="slide-bg" style="background-image: url('/images/homepageSlideshow/c3-health-img-1.png');"></div>
                        <div class="slide-overlay"></div>
                        <div class="slide-content">
                            <span class="slide-tag">Explore Our Collection</span>
                            <h2 class="slide-title">Peptide Inventory</h2>
                            <p class="slide-description">Browse our full catalog of premium, research-grade peptides — sourced with precision and delivered with care.</p>
                            <a href="#" class="slide-cta">Shop Now</a> <!-- /inventory -->
                        </div>
                    </div>

                    <!-- Slide 2: New Features & Peptides -->
                    <div class="slide" data-href="#"> <!-- /new -->
                        <div class="slide-bg" style="background-image: url('/images/homepageSlideshow/c3-health-img-2.png');"></div>
                        <div class="slide-overlay"></div>
                        <div class="slide-content">
                            <span class="slide-tag">Just Arrived</span>
                            <h2 class="slide-title">What's New</h2>
                            <p class="slide-description">Discover the latest peptides and platform features added to C3 Health — stay ahead with cutting-edge compounds.</p>
                            <a href="#" class="slide-cta">See What's New</a> <!-- /new -->
                        </div>
                    </div>

                    <!-- Slide 3: The Science -->
                    <div class="slide" data-href="#"> <!-- /science -->
                        <div class="slide-bg" style="background-image: url('/images/homepageSlideshow/c3-health-img-3.png');"></div>
                        <div class="slide-overlay"></div>
                        <div class="slide-content">
                            <span class="slide-tag">Research & Evidence</span>
                            <h2 class="slide-title">The Science</h2>
                            <p class="slide-description">Deep-dive into the biology and research behind every peptide we carry — transparency you can trust.</p>
                            <a href="#" class="slide-cta">Learn More</a> <!-- /science -->
                        </div>
                    </div>

                    <!-- Navigation Arrows -->
                    <button class="slide-arrow slide-arrow--prev" aria-label="Previous slide">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button class="slide-arrow slide-arrow--next" aria-label="Next slide">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>

                    <!-- Dot Indicators -->
                    <div class="slide-dots">
                        <button class="slide-dot" aria-label="Go to slide 1"></button>
                        <button class="slide-dot" aria-label="Go to slide 2"></button>
                        <button class="slide-dot" aria-label="Go to slide 3"></button>
                    </div>

                    <!-- Progress Bar -->
                    <div class="slide-progress"><div class="slide-progress-bar"></div></div>

                </div>

            </section>


            <!-- Homepage Registration Section -->
            <section class="homepage-registration-section">

                <div class="reg-bg"></div>
                <div class="reg-overlay"></div>

                <div class="reg-content">

                    <div class="reg-text-col">
                        <span class="reg-tag">Become a Member</span>
                        <h2 class="reg-title">Unlock the Full<br>C3 Health Experience</h2>
                        <p class="reg-description">Join thousands of members who trust C3 Health for premium, research-grade peptides backed by science. Registration is free and takes less than a minute.</p>

                        <ul class="reg-benefits">
                            <li class="reg-benefit">
                                <span class="reg-benefit-icon">
                                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>
                                </span>
                                <span>Exclusive member pricing on all peptides</span>
                            </li>
                            <li class="reg-benefit">
                                <span class="reg-benefit-icon">
                                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>
                                </span>
                                <span>Early access to new compounds &amp; research</span>
                            </li>
                            <li class="reg-benefit">
                                <span class="reg-benefit-icon">
                                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>
                                </span>
                                <span>Personalized order history &amp; saved protocols</span>
                            </li>
                            <li class="reg-benefit">
                                <span class="reg-benefit-icon">
                                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>
                                </span>
                                <span>Priority support from our science team</span>
                            </li>
                        </ul>

                        <div class="reg-cta-group">
                            <a href="#" class="reg-cta-primary">Create Free Account</a> <!-- /register -->
                            <a href="#" class="reg-cta-secondary">Already a member? Sign in</a> <!-- /login -->
                        </div>
                    </div>

                </div>

            </section>


            <!-- Homepage News Section -->
            <section class="homepage-news-section">

                <div class="news-section-inner">

                    <!-- Section Header -->
                    <div class="news-header">
                        <div class="news-header-left">
                            <span class="news-tag">Latest Updates</span>
                            <h2 class="news-title">C3 Health News</h2>
                        </div>
                        <a href="#" class="news-view-all"> <!-- /news -->
                            View All
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    </div>

                    <!-- News Grid -->
                    <div class="news-grid">

                        <!-- News Card 1: Peptides & Beauty -->
                        <a href="#" class="news-card news-card--featured"> <!-- /news/peptides-beauty-revolution -->
                            <div class="news-card-img-wrap">
                                <img src="/images/homepageNews/c3-health-news-img-1.png" alt="Peptides and Beauty" class="news-card-img">
                                <div class="news-card-img-overlay"></div>
                                <span class="news-card-category">Beauty &amp; Wellness</span>
                            </div>
                            <div class="news-card-body">
                                <div class="news-card-meta">
                                    <span class="news-card-date">March 28, 2026</span>
                                    <span class="news-card-read-time">5 min read</span>
                                </div>
                                <h3 class="news-card-title">The Peptides Redefining Modern Beauty from the Inside Out</h3>
                                <p class="news-card-excerpt">From collagen synthesis to cellular renewal — discover the science-backed peptides that are transforming skin health and anti-aging protocols.</p>
                                <span class="news-card-cta">
                                    Read More
                                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                                </span>
                            </div>
                        </a>

                        <!-- News Cards 2–4: Side Column -->
                        <div class="news-side-col">

                            <!-- News Card 2: Growing Trend -->
                            <a href="#" class="news-card news-card--side"> <!-- /news/peptide-trend-2026 -->
                                <div class="news-card-img-wrap">
                                    <img src="/images/homepageNews/c3-health-news-img-2.png" alt="Peptide Trend Growth" class="news-card-img">
                                    <div class="news-card-img-overlay"></div>
                                    <span class="news-card-category">Industry Trends</span>
                                </div>
                                <div class="news-card-body">
                                    <div class="news-card-meta">
                                        <span class="news-card-date">March 24, 2026</span>
                                        <span class="news-card-read-time">4 min read</span>
                                    </div>
                                    <h3 class="news-card-title">Why Peptides Are the Fastest-Growing Segment in Health Optimization</h3>
                                    <p class="news-card-excerpt">A deep look at the data and cultural forces driving mainstream adoption of peptide protocols.</p>
                                    <span class="news-card-cta">
                                        Read More
                                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                                    </span>
                                </div>
                            </a>

                            <!-- News Card 3: Scientific Development -->
                            <a href="#" class="news-card news-card--side"> <!-- /news/peptide-science-breakthrough -->
                                <div class="news-card-img-wrap">
                                    <img src="/images/homepageNews/c3-health-news-img-3.png" alt="Peptide Science Breakthrough" class="news-card-img">
                                    <div class="news-card-img-overlay"></div>
                                    <span class="news-card-category">Science &amp; Research</span>
                                </div>
                                <div class="news-card-body">
                                    <div class="news-card-meta">
                                        <span class="news-card-date">March 19, 2026</span>
                                        <span class="news-card-read-time">6 min read</span>
                                    </div>
                                    <h3 class="news-card-title">Groundbreaking Study Unlocks New Mechanisms in Peptide-Driven Cell Repair</h3>
                                    <p class="news-card-excerpt">New peer-reviewed findings reveal how targeted peptide sequences activate dormant repair pathways previously unreachable.</p>
                                    <span class="news-card-cta">
                                        Read More
                                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                                    </span>
                                </div>
                            </a>

                            <!-- News Card 4: Studio Partnerships -->
                            <a href="#" class="news-card news-card--side"> <!-- /news/c3-studio-partnerships -->
                                <div class="news-card-img-wrap">
                                    <img src="/images/homepageNews/c3-health-news-img-4.png" alt="C3 Health Studio Partnerships" class="news-card-img">
                                    <div class="news-card-img-overlay"></div>
                                    <span class="news-card-category">Partnerships</span>
                                </div>
                                <div class="news-card-body">
                                    <div class="news-card-meta">
                                        <span class="news-card-date">March 14, 2026</span>
                                        <span class="news-card-read-time">3 min read</span>
                                    </div>
                                    <h3 class="news-card-title">C3 Health Partners with SOSU Studio &amp; Elite Wellness Networks</h3>
                                    <p class="news-card-excerpt">Announcing our new alliances with SOSU Studio and a growing roster of premier wellness studios bringing C3 protocols directly to members.</p>
                                    <span class="news-card-cta">
                                        Read More
                                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                                    </span>
                                </div>
                            </a>

                        </div>
                    </div>

                </div>

            </section>


            <!-- Homepage Features Section -->
            <section class="homepage-features-section">

                <div class="feat-bg"></div>
                <div class="feat-overlay"></div>

                <div class="feat-content">

                    <!-- Section Header -->
                    <div class="feat-header">
                        <span class="feat-tag">Newcomer's Guide</span>
                        <h2 class="feat-title">Everything You Need to<br>Start with Confidence</h2>
                        <p class="feat-description">New to peptides? We've built a complete learning hub — covering the biology, safe usage routines, and step-by-step guides so you can begin your journey the right way.</p>
                    </div>

                    <!-- Feature Cards -->
                    <div class="feat-grid">

                        <!-- Card 1: The Science -->
                        <div class="feat-card">
                            <div class="feat-card-icon-wrap">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M6 3c0 0 1.5 4 6 6s6 6 6 6"/>
                                    <path d="M18 3c0 0-1.5 4-6 6S6 15 6 15"/>
                                    <line x1="6" y1="3" x2="6" y2="4"/>
                                    <line x1="18" y1="3" x2="18" y2="4"/>
                                    <line x1="6" y1="20" x2="6" y2="15"/>
                                    <line x1="18" y1="20" x2="18" y2="15"/>
                                </svg>
                            </div>
                            <span class="feat-card-number">01</span>
                            <h3 class="feat-card-title">The Science of Peptides</h3>
                            <p class="feat-card-description">Understand what peptides are at a molecular level — how they signal cells, trigger repair, and interact with your body's natural biological pathways.</p>
                            <a href="#" class="feat-card-link"> <!-- /learn/science -->
                                Explore the Science
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                            </a>
                        </div>

                        <!-- Card 2: Building a Routine (highlighted) -->
                        <div class="feat-card feat-card--highlight">
                            <div class="feat-card-icon-wrap">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                    <polyline points="9 16 11 18 15 14"/>
                                </svg>
                            </div>
                            <span class="feat-card-number">02</span>
                            <h3 class="feat-card-title">Building Your Routine</h3>
                            <p class="feat-card-description">Learn how to structure effective peptide protocols — timing, cycling, and stacking principles used by researchers and practitioners worldwide.</p>
                            <a href="#" class="feat-card-link"> <!-- /learn/routines -->
                                Build Your Protocol
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                            </a>
                        </div>

                        <!-- Card 3: How to Use -->
                        <div class="feat-card">
                            <div class="feat-card-icon-wrap">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M14.5 2.5l7 7"/>
                                    <path d="M12 5l7 7"/>
                                    <line x1="5" y1="14" x2="2" y2="22"/>
                                    <path d="M5 14l9-9"/>
                                    <path d="M9 10l5 5"/>
                                    <path d="M2 22l5-2"/>
                                </svg>
                            </div>
                            <span class="feat-card-number">03</span>
                            <h3 class="feat-card-title">How to Use Peptides</h3>
                            <p class="feat-card-description">Step-by-step administration guides covering reconstitution, dosing, storage, and safe handling — written specifically for first-time users.</p>
                            <a href="#" class="feat-card-link"> <!-- /learn/how-to-use -->
                                Read the Guide
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                            </a>
                        </div>

                    </div>

                    <!-- Bottom CTA -->
                    <div class="feat-cta-wrap">
                        <a href="#" class="feat-cta-primary"> <!-- /learn -->
                            Visit the Learning Hub
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                        <p class="feat-cta-note">Free for all members &amp; visitors — no account required</p>
                    </div>

                </div>

            </section>
        </main>

        <!-- Public Footer -->
        <%- include('../utils/footer.ejs') %>
    </body>
</html>